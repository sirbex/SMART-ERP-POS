{
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "title": "HTTP Request Rate (req/s)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "color": {
                        "mode": "palette-classic"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rate(app_http_requests_total[5m])",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "HTTP Error Rate (5xx/s)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "red"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 0.05
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rate(app_http_errors_total[5m])",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Sales Created (total)",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "green"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "sum(app_sales_created_total)",
                    "legendFormat": "Sales",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Banking Retries (total)",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "orange"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 20
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "sum(app_banking_retries_total)",
                    "legendFormat": "Retries",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Error Rate %",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.01
                            },
                            {
                                "color": "red",
                                "value": 0.05
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "sum(rate(app_http_errors_total[5m])) / sum(rate(app_http_requests_total[5m]))",
                    "legendFormat": "Error %",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Uptime (seconds)",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "blue"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "process_uptime_seconds",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Heap Memory (MB)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 12
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "color": {
                        "mode": "palette-classic"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "process_heap_bytes{type=\"used\"}",
                    "legendFormat": "{{instance}} used",
                    "refId": "A"
                },
                {
                    "expr": "process_heap_bytes{type=\"total\"}",
                    "legendFormat": "{{instance}} total",
                    "refId": "B"
                }
            ]
        },
        {
            "title": "RSS Memory",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 12
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "color": {
                        "mode": "palette-classic"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "process_rss_bytes",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "DB Connection Pool",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "palette-classic"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "db_pool_connections{state=\"total\"}",
                    "legendFormat": "{{instance}} total",
                    "refId": "A"
                },
                {
                    "expr": "db_pool_connections{state=\"idle\"}",
                    "legendFormat": "{{instance}} idle",
                    "refId": "B"
                },
                {
                    "expr": "db_pool_connections{state=\"waiting\"}",
                    "legendFormat": "{{instance}} waiting",
                    "refId": "C"
                }
            ]
        },
        {
            "title": "Sales Rate (sales/min)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "opm",
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "green"
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rate(app_sales_created_total[5m]) * 60",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "30s",
