# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Configuration
PGHOST=localhost
PGUSER=postgres
PGDATABASE=samplepos
PGPASSWORD=postgres
PGPORT=5432

# JWT Configuration (for authentication)
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=1d

# Logging
LOG_LEVEL=debug