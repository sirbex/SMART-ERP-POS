            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleId\": \"{{saleId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"downPayment\": 5000.00,\n  \"numberOfInstallments\": 6,\n  \"frequency\": \"MONTHLY\",\n  \"interestRate\": 0.05,\n  \"startDate\": \"2025-11-01\"\n}"
