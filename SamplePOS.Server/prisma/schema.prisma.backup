generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  username            String               @unique
  email               String               @unique
  passwordHash        String
  fullName            String
  role                UserRole             @default(CASHIER)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  documents           Document[]
  installmentPayments InstallmentPayment[] @relation("InstallmentPaymentProcessor")
  installmentPlans    InstallmentPlan[]    @relation("InstallmentPlanCreator")
  purchases           Purchase[]
  sales               Sale[]
  supplierPayments    SupplierPayment[]    @relation("SupplierPaymentProcessor")

  @@index([username])
  @@index([email])
  @@map("users")
}

model Product {
  id               String         @id @default(cuid())
  barcode          String?        @unique
  name             String
  description      String?
  category         String?
  baseUnit         String
  currentStock     Decimal        @default(0) @db.Decimal(15, 4)
  reorderLevel     Decimal        @default(0) @db.Decimal(15, 4)
  costPrice        Decimal        @default(0) @db.Decimal(15, 2)
  sellingPrice     Decimal        @db.Decimal(15, 2)
  hasMultipleUnits Boolean        @default(false)
  alternateUnit    String?
  conversionFactor Decimal?       @db.Decimal(15, 4)
  taxRate          Decimal        @default(0) @db.Decimal(5, 4)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  purchaseItems    PurchaseItem[]
  saleItems        SaleItem[]
  stockBatches     StockBatch[]

  @@index([barcode])
  @@index([name])
  @@index([category])
  @@map("products")
}

model StockBatch {
  id                String     @id @default(cuid())
  productId         String
  batchNumber       String
  purchaseId        String?
  quantityReceived  Decimal    @db.Decimal(15, 4)
  quantityRemaining Decimal    @db.Decimal(15, 4)
  unitCost          Decimal    @db.Decimal(15, 2)
  receivedDate      DateTime   @default(now())
  expiryDate        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  SaleItem          SaleItem[]
  product           Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase          Purchase?  @relation(fields: [purchaseId], references: [id])

  @@index([productId])
  @@index([batchNumber])
  @@index([receivedDate])
  @@map("stock_batches")
}

model Customer {
  id               String                @id @default(cuid())
  name             String
  phone            String?
  email            String?
  address          String?
  taxId            String?
  creditLimit      Decimal               @default(0) @db.Decimal(15, 2)
  currentBalance   Decimal               @default(0) @db.Decimal(15, 2)
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  accountStatus    String                @default("ACTIVE")
  autoApplyDeposit Boolean               @default(true)
  creditScore      Int                   @default(100)
  creditUsed       Decimal               @default(0) @db.Decimal(15, 2)
  depositBalance   Decimal               @default(0) @db.Decimal(15, 2)
  interestRate     Decimal               @default(0) @db.Decimal(5, 4)
  lastPaymentDate  DateTime?
  lastPurchaseDate DateTime?
  lifetimeValue    Decimal               @default(0) @db.Decimal(15, 2)
  paymentTermsDays Int                   @default(0)
  totalPayments    Decimal               @default(0) @db.Decimal(15, 2)
  totalPurchases   Decimal               @default(0) @db.Decimal(15, 2)
  transactions     CustomerTransaction[]
  installmentPlans InstallmentPlan[]
  sales            Sale[]

  @@index([name])
  @@index([phone])
  @@map("customers")
}

model CustomerTransaction {
  id                  String               @id @default(cuid())
  customerId          String
  type                String
  amount              Decimal              @db.Decimal(15, 2)
  balance             Decimal              @db.Decimal(15, 2)
  description         String?
  referenceId         String?
  createdAt           DateTime             @default(now())
  createdBy           String?
  documentNumber      String?
  dueDate             DateTime?
  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  installmentPayments InstallmentPayment[]

  @@index([customerId])
  @@index([createdAt])
  @@map("customer_transactions")
}

model Supplier {
  id              String            @id @default(cuid())
  name            String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  taxId           String?
  currentBalance  Decimal           @default(0) @db.Decimal(15, 2)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accountBalance  Decimal           @default(0) @db.Decimal(15, 2)
  lastPaymentDate DateTime?
  paymentTerms    String?
  totalPaid       Decimal           @default(0) @db.Decimal(15, 2)
  totalPurchased  Decimal           @default(0) @db.Decimal(15, 2)
  purchases       Purchase[]
  payments        SupplierPayment[]

  @@index([name])
  @@map("suppliers")
}

model Purchase {
  id               String            @id @default(cuid())
  purchaseNumber   String            @unique
  supplierId       String
  orderDate        DateTime          @default(now())
  receivedDate     DateTime?
  status           PurchaseStatus    @default(PENDING)
  subtotal         Decimal           @db.Decimal(15, 2)
  taxAmount        Decimal           @default(0) @db.Decimal(15, 2)
  totalAmount      Decimal           @db.Decimal(15, 2)
  amountPaid       Decimal           @default(0) @db.Decimal(15, 2)
  paymentMethod    PaymentMethod?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      String
  items            PurchaseItem[]
  createdBy        User              @relation(fields: [createdById], references: [id])
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  stockBatches     StockBatch[]
  supplierPayments SupplierPayment[]

  @@index([supplierId])
  @@index([purchaseNumber])
  @@index([orderDate])
  @@map("purchases")
}

model PurchaseItem {
  id             String   @id @default(cuid())
  purchaseId     String
  productId      String
  quantity       Decimal  @db.Decimal(15, 4)
  unit           String
  quantityInBase Decimal  @db.Decimal(15, 4)
  unitCost       Decimal  @db.Decimal(15, 2)
  subtotal       Decimal  @db.Decimal(15, 2)
  taxRate        Decimal  @default(0) @db.Decimal(5, 4)
  taxAmount      Decimal  @default(0) @db.Decimal(15, 2)
  total          Decimal  @db.Decimal(15, 2)
  product        Product  @relation(fields: [productId], references: [id])
  purchase       Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model Sale {
  id                 String            @id @default(cuid())
  saleNumber         String            @unique
  customerId         String?
  saleDate           DateTime          @default(now())
  status             SaleStatus        @default(COMPLETED)
  subtotal           Decimal           @db.Decimal(15, 2)
  taxAmount          Decimal           @default(0) @db.Decimal(15, 2)
  discount           Decimal           @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal           @db.Decimal(15, 2)
  totalCost          Decimal           @default(0) @db.Decimal(15, 2)
  profit             Decimal           @default(0) @db.Decimal(15, 2)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdById        String
  amountOutstanding  Decimal           @default(0) @db.Decimal(15, 2)
  amountPaid         Decimal           @default(0) @db.Decimal(15, 2)
  deliveryNoteNumber String?
  deliveryStatus     String            @default("PENDING")
  documentType       String            @default("RECEIPT")
  invoiceGenerated   Boolean           @default(false)
  paymentStatus      String            @default("UNPAID")
  profitMargin       Decimal           @default(0) @db.Decimal(5, 4)
  receiptGenerated   Boolean           @default(false)
  installmentPlans   InstallmentPlan[]
  payments           Payment[]
  items              SaleItem[]
  createdBy          User              @relation(fields: [createdById], references: [id])
  customer           Customer?         @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([saleNumber])
  @@index([saleDate])
  @@map("sales")
}

model SaleItem {
  id             String      @id @default(cuid())
  saleId         String
  productId      String
  quantity       Decimal     @db.Decimal(15, 4)
  unit           String
  quantityInBase Decimal     @db.Decimal(15, 4)
  unitPrice      Decimal     @db.Decimal(15, 2)
  unitCost       Decimal     @default(0) @db.Decimal(15, 2)
  subtotal       Decimal     @db.Decimal(15, 2)
  taxRate        Decimal     @default(0) @db.Decimal(5, 4)
  taxAmount      Decimal     @default(0) @db.Decimal(15, 2)
  discount       Decimal     @default(0) @db.Decimal(15, 2)
  total          Decimal     @db.Decimal(15, 2)
  costTotal      Decimal     @default(0) @db.Decimal(15, 2)
  profit         Decimal     @default(0) @db.Decimal(15, 2)
  batchId        String?
  lineCost       Decimal     @default(0) @db.Decimal(15, 2)
  lineProfit     Decimal     @default(0) @db.Decimal(15, 2)
  profitMargin   Decimal     @default(0) @db.Decimal(5, 4)
  batch          StockBatch? @relation(fields: [batchId], references: [id])
  product        Product     @relation(fields: [productId], references: [id])
  sale           Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Payment {
  id        String        @id @default(cuid())
  saleId    String
  amount    Decimal       @db.Decimal(15, 2)
  method    PaymentMethod @default(CASH)
  reference String?
  notes     String?
  createdAt DateTime      @default(now())
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("payments")
}

model InstallmentPlan {
  id                   String               @id @default(cuid())
  customerId           String
  saleId               String?
  planName             String
  totalAmount          Decimal              @db.Decimal(15, 2)
  paidAmount           Decimal              @default(0) @db.Decimal(15, 2)
  outstandingAmount    Decimal              @db.Decimal(15, 2)
  numberOfInstallments Int
  installmentAmount    Decimal              @db.Decimal(15, 2)
  frequency            String               @default("MONTHLY")
  startDate            DateTime
  endDate              DateTime
  nextDueDate          DateTime?
  status               String               @default("ACTIVE")
  interestRate         Decimal              @default(0) @db.Decimal(5, 4)
  lateFeesAccrued      Decimal              @default(0) @db.Decimal(15, 2)
  notes                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  createdById          String
  payments             InstallmentPayment[]
  createdBy            User                 @relation("InstallmentPlanCreator", fields: [createdById], references: [id])
  customer             Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale                 Sale?                @relation(fields: [saleId], references: [id])

  @@index([customerId])
  @@index([saleId])
  @@index([status])
  @@index([nextDueDate])
  @@map("installment_plans")
}

model InstallmentPayment {
  id                String               @id @default(cuid())
  installmentPlanId String
  transactionId     String?
  installmentNumber Int
  dueDate           DateTime
  dueAmount         Decimal              @db.Decimal(15, 2)
  paidAmount        Decimal              @default(0) @db.Decimal(15, 2)
  paidDate          DateTime?
  lateFee           Decimal              @default(0) @db.Decimal(15, 2)
  status            String               @default("PENDING")
  paymentMethod     PaymentMethod?
  reference         String?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  processedById     String?
  plan              InstallmentPlan      @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)
  processedBy       User?                @relation("InstallmentPaymentProcessor", fields: [processedById], references: [id])
  transaction       CustomerTransaction? @relation(fields: [transactionId], references: [id])

  @@index([installmentPlanId])
  @@index([transactionId])
  @@index([dueDate])
  @@index([status])
  @@map("installment_payments")
}

model SupplierPayment {
  id              String        @id @default(cuid())
  supplierId      String
  purchaseId      String?
  amount          Decimal       @db.Decimal(15, 2)
  paymentDate     DateTime      @default(now())
  paymentMethod   PaymentMethod @default(CASH)
  referenceNumber String?
  checkNumber     String?
  cardLast4       String?
  bankReference   String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  processedById   String
  processedBy     User          @relation("SupplierPaymentProcessor", fields: [processedById], references: [id])
  purchase        Purchase?     @relation(fields: [purchaseId], references: [id])
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([purchaseId])
  @@index([paymentDate])
  @@map("supplier_payments")
}

model Document {
  id             String       @id @default(cuid())
  documentNumber String       @unique
  documentType   DocumentType
  referenceId    String?
  customerId     String?
  supplierId     String?
  content        String
  createdAt      DateTime     @default(now())
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])

  @@index([documentNumber])
  @@index([documentType])
  @@index([referenceId])
  @@map("documents")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  CREDIT
  BANK_TRANSFER
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum DocumentType {
  SALE_INVOICE
  SALE_RECEIPT
  PURCHASE_ORDER
  PURCHASE_RECEIPT
  CREDIT_NOTE
  CUSTOMER_STATEMENT
  SUPPLIER_STATEMENT
}
