// Complete Prisma Schema for POS System
// Copy this to: pos-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT & AUTHENTICATION
// ============================================================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Hashed with bcrypt
  name      String
  role      UserRole @default(CASHIER)
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sales     Sale[]
  purchases Purchase[]

  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

// ============================================================================
// PRODUCT & INVENTORY MANAGEMENT
// ============================================================================

model Product {
  id              Int            @id @default(autoincrement())
  sku             String         @unique
  name            String
  description     String?
  category        String?
  basePrice       Decimal        @db.Decimal(12, 2)
  costPrice       Decimal        @db.Decimal(12, 2)
  taxRate         Decimal        @default(0) @db.Decimal(5, 2)
  reorderLevel    Int            @default(10)
  baseUnit        String         // Primary unit: "pcs", "kg", "liter"
  isActive        Boolean        @default(true)
  imageUrl        String?
  barcode         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  units           ProductUnit[]
  batches         StockBatch[]
  purchaseItems   PurchaseItem[]
  saleItems       SaleItem[]

  @@index([sku])
  @@index([category])
  @@map("products")
}

// Multi-UOM Support
model ProductUnit {
  id              Int      @id @default(autoincrement())
  productId       Int
  unitName        String   // e.g., "box", "carton", "dozen", "case"
  conversionRate  Decimal  @db.Decimal(10, 4) // How many base units in this unit
  isBaseUnit      Boolean  @default(false)
  barcode         String?
  sellingPrice    Decimal? @db.Decimal(12, 2) // Optional: different price per unit
  createdAt       DateTime @default(now())

  // Relations
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, unitName])
  @@index([productId])
  @@map("product_units")
}

// FIFO Inventory Batches
model StockBatch {
  id                Int       @id @default(autoincrement())
  productId         Int
  batchNumber       String
  initialQuantity   Decimal   @db.Decimal(12, 4) // In base units
  remainingQuantity Decimal   @db.Decimal(12, 4) // In base units
  unitCost          Decimal   @db.Decimal(12, 2) // Cost per base unit
  supplierInvoice   String?
  purchaseId        Int?
  receivedDate      DateTime  @default(now())
  expiryDate        DateTime?
  location          String?
  notes             String?
  createdAt         DateTime  @default(now())

  // Relations
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, remainingQuantity])
  @@index([receivedDate])
  @@map("stock_batches")
}

// ============================================================================
// CUSTOMER MANAGEMENT
// ============================================================================

model Customer {
  id              Int              @id @default(autoincrement())
  customerCode    String           @unique
  name            String
  email           String?          @unique
  phone           String?
  address         String?
  taxId           String?
  creditLimit     Decimal          @default(0) @db.Decimal(12, 2)
  currentBalance  Decimal          @default(0) @db.Decimal(12, 2) // Positive = owes us
  totalDeposits   Decimal          @default(0) @db.Decimal(12, 2)
  isActive        Boolean          @default(true)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  sales           Sale[]
  transactions    CustomerTransaction[]

  @@index([customerCode])
  @@index([email])
  @@map("customers")
}

model CustomerTransaction {
  id          Int                     @id @default(autoincrement())
  customerId  Int
  type        CustomerTransactionType
  amount      Decimal                 @db.Decimal(12, 2)
  reference   String?                 // Invoice number, payment ref, etc.
  notes       String?
  createdBy   String?
  createdAt   DateTime                @default(now())

  // Relations
  customer    Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@map("customer_transactions")
}

enum CustomerTransactionType {
  SALE          // Money owed to us
  PAYMENT       // Money received
  DEPOSIT       // Prepayment
  REFUND        // Money returned
  ADJUSTMENT    // Balance correction
}

// ============================================================================
// SUPPLIER MANAGEMENT
// ============================================================================

model Supplier {
  id              Int       @id @default(autoincrement())
  supplierCode    String    @unique
  name            String
  email           String?   @unique
  phone           String?
  address         String?
  taxId           String?
  paymentTerms    String?   // e.g., "Net 30", "COD"
  currentBalance  Decimal   @default(0) @db.Decimal(12, 2) // Positive = we owe them
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  purchases       Purchase[]

  @@index([supplierCode])
  @@index([email])
  @@map("suppliers")
}

// ============================================================================
// PURCHASE ORDERS & RECEIVING
// ============================================================================

model Purchase {
  id                Int            @id @default(autoincrement())
  purchaseNumber    String         @unique
  supplierId        Int
  userId            Int
  totalAmount       Decimal        @db.Decimal(12, 2)
  taxAmount         Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(12, 2)
  shippingCost      Decimal        @default(0) @db.Decimal(12, 2)
  finalAmount       Decimal        @db.Decimal(12, 2)
  paidAmount        Decimal        @default(0) @db.Decimal(12, 2)
  status            PurchaseStatus @default(PENDING)
  purchaseDate      DateTime       @default(now())
  receivedDate      DateTime?
  dueDate           DateTime?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  supplier          Supplier       @relation(fields: [supplierId], references: [id])
  user              User           @relation(fields: [userId], references: [id])
  items             PurchaseItem[]

  @@index([purchaseNumber])
  @@index([supplierId])
  @@index([status])
  @@map("purchases")
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  productId   Int
  quantity    Decimal  @db.Decimal(12, 4)
  unitCost    Decimal  @db.Decimal(12, 2)
  totalCost   Decimal  @db.Decimal(12, 2)
  unit        String   // Which UOM was used
  batchNumber String?
  expiryDate  DateTime?
  received    Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Relations
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELLED
}

// ============================================================================
// SALES & TRANSACTIONS
// ============================================================================

model Sale {
  id              Int         @id @default(autoincrement())
  invoiceNumber   String      @unique
  customerId      Int?
  userId          Int
  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  paidAmount      Decimal     @db.Decimal(12, 2)
  outstandingAmount Decimal   @default(0) @db.Decimal(12, 2)
  costOfGoods     Decimal     @db.Decimal(12, 2) // FIFO calculated COGS
  profit          Decimal     @db.Decimal(12, 2) // totalAmount - costOfGoods
  status          SaleStatus  @default(COMPLETED)
  saleDate        DateTime    @default(now())
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  customer        Customer?   @relation(fields: [customerId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
  items           SaleItem[]
  payments        Payment[]
  documents       Document[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([saleDate])
  @@map("sales")
}

model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      Int
  productId   Int
  quantity    Decimal @db.Decimal(12, 4)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  costPrice   Decimal @db.Decimal(12, 2) // FIFO calculated cost
  unit        String
  discount    Decimal @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  // Relations
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Payment {
  id            Int          @id @default(autoincrement())
  saleId        Int
  amount        Decimal      @db.Decimal(12, 2)
  method        PaymentMethod
  reference     String?      // Transaction ref, check number, etc.
  notes         String?
  createdAt     DateTime     @default(now())

  // Relations
  sale          Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  DEPOSIT       // Use customer deposit
  CREDIT        // Add to customer balance
  CHECK
}

enum SaleStatus {
  COMPLETED
  PENDING
  PARTIAL
  CANCELLED
  REFUNDED
}

// ============================================================================
// DOCUMENTS (Invoice, Delivery Note, Receipt)
// ============================================================================

model Document {
  id              Int           @id @default(autoincrement())
  documentNumber  String        @unique
  type            DocumentType
  saleId          Int?
  content         String        @db.Text // JSON stringified data
  pdfUrl          String?
  generatedAt     DateTime      @default(now())

  // Relations
  sale            Sale?         @relation(fields: [saleId], references: [id])

  @@index([documentNumber])
  @@index([type])
  @@map("documents")
}

enum DocumentType {
  INVOICE
  DELIVERY_NOTE
  RECEIPT
  QUOTATION
  PURCHASE_ORDER
}

// ============================================================================
// SETTINGS & CONFIGURATION
// ============================================================================

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  category  String?  // e.g., "company", "tax", "currency"
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("settings")
}

// Example settings:
// - company_name
// - company_address
// - company_tax_id
// - currency
// - tax_rate
// - invoice_prefix (INV-)
// - next_invoice_number
// - delivery_note_prefix (DN-)
// - receipt_prefix (RCPT-)
