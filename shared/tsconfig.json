{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx"
  },
  "include": [
    "zod/**/*",
    "types/**/*",
    "components/pos/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}