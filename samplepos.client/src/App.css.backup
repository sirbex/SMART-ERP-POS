@tailwind base;
@tailwind components;
@tailwind utilities;

/* Custom component styles that extend Tailwind */
@layer components {
  /* POS cart table styles */
  .pos-cart-table {
    @apply w-full border-separate border-spacing-0 rounded-lg overflow-hidden shadow-sm mt-4 mb-4;
  }
  
  .pos-cart-table th {
    @apply bg-gray-100 font-semibold p-3 border-b-2 border-gray-200 rounded-t-md;
  }
  
  .pos-cart-table td {
    @apply p-3 border-b border-gray-100 text-gray-700 font-medium;
    background: linear-gradient(90deg, #e6eaf3 0%, #f3f4f6 100%);
  }
  
  /* POS button styles */
  .pos-button {
    @apply bg-blue-500 text-white rounded-md px-4 py-2 m-1 shadow-sm hover:bg-blue-600 transition-colors;
  }
  
  .pos-button-secondary {
    @apply bg-gray-300 text-gray-700 rounded-md px-4 py-2 m-1 shadow-sm hover:bg-gray-400 transition-colors;
  }
  
  .pos-button-danger {
    @apply bg-red-500 text-white rounded-md px-4 py-2 m-1 shadow-sm hover:bg-red-600 transition-colors;
  }
  
  .pos-input {
    @apply border border-gray-300 rounded-md px-3 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500;
  }
}

/* POS cart table row and cell alignment fix */

.pos-cart-table th,
.pos-cart-table td {
    vertical-align: middle;
    padding: 0.7em 0.5em;
    height: 3.2em;
    box-sizing: border-box;
}
.pos-cart-table input.pos-cart-qty {
    margin: 0;
    vertical-align: middle;
    display: inline-block;
}
#pos-root, .pos-screen, .inventory-form-container, .customer-ledger-container, .payment-form-container, .reports-container {
    box-shadow: var(--shadow-md);
    border-radius: var(--border-radius-lg);
    background: var(--color-surface);
    margin: var(--space-lg) auto;
    padding: var(--space-xl) var(--space-lg);
    max-width: 1600px;
    width: 100%;
}
.pos-cart-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: var(--color-background-alt);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
}
.pos-cart-table th {
    border-radius: 12px;
    margin-top: 1.2rem;
    margin-bottom: 1.2rem;
    background: #f3f4f6;
    font-weight: 600;
    padding: 0.8rem 0.5rem;
    border-bottom: 2px solid #e5e7eb;
}
.pos-cart-table td {
        background: linear-gradient(90deg, #e6eaf3 0%, #f3f4f6 100%);
        font-weight: 700;
        padding: 1rem 0.7rem;
        color: #2d3748;
        letter-spacing: 0.03em;
        font-size: 1.05rem;
    border-bottom: 1px solid #f1f1f1;
}
.pos-cart-table tr:last-child td {
    border-bottom: none;
    padding: 0.7em 0.5em;
    font-size: 1.05rem;
}
.pos-cart-export, .pos-hide-cart-btn, .pos-show-cart-btn, .pos-cart-save, .pos-cart-recall, .pos-payment-btn {
        background: #e6eaf3;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.6rem 1.2rem;
    margin: 0.3rem 0.5rem 0.3rem 0;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: 0 2px 8px #e0e7ef;
    transition: background 0.18s;
}
.pos-cart-export:hover, .pos-hide-cart-btn:hover, .pos-show-cart-btn:hover, .pos-cart-save:hover, .pos-cart-recall:hover, .pos-payment-btn:hover {
        padding: 0.45rem 1rem;
        font-size: 0.97rem;
        transition: background 0.15s, box-shadow 0.15s;
        box-shadow: 0 1px 4px #e0e7ef;
}
.pos-search-input, .pos-customer-input, .pos-note-input, .pos-cart-qty, .pos-total-discount, .pos-total-tax {
    border: 1px solid #e0e7ef;
        box-shadow: 0 2px 8px #c3d3e7;
    padding: 0.7rem 1rem;
    font-size: 1rem;
    margin: 0.2rem 0.5rem;
    background: #f9fafb;
    transition: border 0.15s;
}
.pos-search-input:focus, .pos-customer-input:focus, .pos-note-input:focus, .pos-cart-qty:focus, .pos-total-discount:focus, .pos-total-tax:focus {
    border: 1.5px solid #0078d4;
    outline: none;
}
.pos-cart-edit, .pos-cart-remove {
    background: #f3f4f6;
    color: #555;
    border: none;
    border-radius: 6px;
    padding: 0.4rem 0.9rem;
    margin: 0.2rem;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s;
}
.pos-cart-edit:hover, .pos-cart-remove:hover {
    background: #e6eaf3;
}
/* CSS root variables are now imported from variables.css */
/* Variables below are for backward compatibility with existing components */
:root {
  /* These match our variables.css definitions */
  --sidebar-width: 220px;
  --sidebar-collapsed-width: 60px;
  --header-height: 60px;
  
  /* Backward compatibility mappings */
  --radius-sm: var(--border-radius-sm);
  --radius-md: var(--border-radius);
  --radius-lg: var(--border-radius-lg);
  
  --card-bg: var(--color-surface);
  --background-color: var(--color-background);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  line-height: 1.5;
  color: var(--text-color);
}

#root {
  width: 100vw;
  min-height: 100vh;
  margin: 0;
  padding: 0;
  text-align: left;
  background: var(--background-color);
}

@media (max-width: 900px) {
  #root {
    padding: 0;
  }
}

th, td {
    padding-left: 1rem;
    padding-right: 1rem;
}
.app-main-layout {
  display: flex;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

.app-main-content {
  margin-left: 220px;
  width: calc(100% - 220px);
  padding: 1rem;
  box-sizing: border-box;
  transition: margin-left 0.3s ease;
}

/* Make app responsive for tablets and mobile */
@media (max-width: 768px) {
  .app-main-content {
    margin-left: 0;
    width: 100%;
    padding: 1rem;
    padding-top: 60px; /* Space for the mobile menu toggle */
  }
  
  #pos-root, .pos-screen, .inventory-form-container, 
  .customer-ledger-container, .payment-form-container, .reports-container {
    margin: 0.5rem auto;
    padding: 1rem;
    width: 100%;
    overflow-x: hidden;
  }
  
  /* Stack content vertically on mobile */
  .pos-cart-table, .transactions-table, .inventory-table {
    font-size: 0.9rem;
  }
  
  /* Adjust button sizes for touch */
  .pos-cart-export, .pos-hide-cart-btn, .pos-show-cart-btn, 
  .pos-cart-save, .pos-cart-recall, .pos-payment-btn {
    padding: 0.7rem 1rem;
    margin: 0.2rem;
    font-size: 0.95rem;
  }
}

.error-page {
  padding: var(--space-xl);
  max-width: 600px;
  margin: var(--space-xl) auto;
  background: var(--color-surface);
  box-shadow: var(--shadow);
  border-radius: var(--border-radius-lg);
  text-align: center;
}

.error-page h2 {
  color: var(--danger-color);
  margin-bottom: var(--space-md);
}

.error-page p {
  margin-bottom: var(--space-lg);
  color: var(--gray-600);
}

.error-page button {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border: none;
  border-radius: var(--border-radius);
  padding: var(--space-sm) var(--space-lg);
  font-size: var(--font-size-base);
  cursor: pointer;
}

.error-page button:hover {
  background: var(--color-primary-dark);
}

.error-boundary-fallback {
  padding: 1.5rem;
  background: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  margin: 1rem 0;
}

.error-boundary-fallback h3 {
  color: #d32f2f;
  margin-top: 0;
}

.error-boundary-reset {
  background: #0078d4;
  color: white;
  border: none;
  border-radius: 4px;
  padding: 0.5rem 1rem;
  font-size: 0.9rem;
  cursor: pointer;
  margin-top: 1rem;
}

.error-boundary-fallback details {
  margin-top: 1rem;
  padding: 0.5rem;
  background: #f5f5f5;
  border-radius: 4px;
}

.error-boundary-fallback summary {
  cursor: pointer;
  color: #666;
  font-weight: 500;
}

.error-boundary-fallback pre {
  margin-top: 0.5rem;
  padding: 0.5rem;
  background: #eee;
  border-radius: 4px;
  overflow-x: auto;
  font-size: 0.8rem;
}