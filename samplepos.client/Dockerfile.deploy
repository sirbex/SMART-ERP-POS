# Frontend deploy Dockerfile — build context is project ROOT (not samplepos.client/)
# so that ../shared/ is accessible for @shared/* path aliases.

FROM node:22-alpine AS base

# Build stage
FROM base AS builder
WORKDIR /app/samplepos.client

# Copy shared types first (referenced via @shared/* alias)
COPY shared/ /app/shared/

# Install deps
COPY samplepos.client/package.json samplepos.client/package-lock.json* ./
RUN npm install --no-audit --no-fund

# Symlink node_modules at /app/ level so shared/ files can resolve 'zod' etc.
RUN ln -s /app/samplepos.client/node_modules /app/node_modules

# Copy frontend source
COPY samplepos.client/ .

# Build (skip tsc type-check — Vite/esbuild handles transpilation;
# type-checking runs in local dev and CI)
ENV NODE_ENV=production
# Use relative URLs so nginx reverse proxy handles /api/ routing
ENV VITE_API_URL=/api
ENV VITE_API_BASE_URL=
# Limit Node.js heap to avoid OOM on low-memory servers (production is 2GB)
ENV NODE_OPTIONS="--max-old-space-size=768"
RUN npx vite build

# Production image — serve with nginx
FROM nginx:alpine AS runner
WORKDIR /usr/share/nginx/html

RUN rm -rf ./*
COPY --from=builder /app/samplepos.client/dist .
COPY --from=builder /app/samplepos.client/nginx.conf /etc/nginx/conf.d/default.conf

# Fix pid path for non-root nginx user
RUN sed -i 's|pid.*\/run\/nginx.pid;|pid /tmp/nginx.pid;|' /etc/nginx/nginx.conf

RUN chown -R nginx:nginx /usr/share/nginx/html \
    && chown -R nginx:nginx /var/cache/nginx \
    && chown -R nginx:nginx /etc/nginx/conf.d \
    && chown -R nginx:nginx /var/log/nginx \
    && touch /tmp/nginx.pid && chown nginx:nginx /tmp/nginx.pid

USER nginx
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
