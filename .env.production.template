# Phase 6: Environment Configuration Templates

# Production Environment Variables
# Copy to .env.production and configure with actual values
#
# ============================================================
# REQUIRED VARIABLES (server refuses to start without these)
# ============================================================
# DATABASE_URL    - PostgreSQL connection string
# JWT_SECRET      - Minimum 32 characters, random, unique per environment
#
# ============================================================
# STRONGLY RECOMMENDED (warnings logged if missing)
# ============================================================
# SENTRY_DSN      - Error tracking. Without this, production errors
#                   only appear in logs — no alerting, no stack traces
#                   in a dashboard. Get a free DSN at https://sentry.io
# REDIS_URL       - Required for job queues (banking retries, CSV imports).
#                   If missing, background jobs fail silently.
# CORS_ORIGIN     - Comma-separated list of allowed frontend origins.
#                   MUST be explicit URLs (e.g. https://pos.example.com).
#                   Wildcard (*) is BLOCKED in production.
#                   Default (if unset): http://localhost:5173
#
# ============================================================

# Database Configuration
POSTGRES_DB=pos_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/pos_system

# Redis Configuration
REDIS_URL=redis://redis:6379

# Application Security
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
ACCOUNTING_API_KEY=your_accounting_api_shared_secret_key

# CORS — Comma-separated allowed origins (NO wildcards in production)
# Example: https://pos.example.com,https://admin.example.com
CORS_ORIGIN=https://pos.example.com

# API URLs
FRONTEND_URL=https://pos.example.com
BACKEND_URL=http://localhost:3001
ACCOUNTING_API_URL=http://accounting-api:5062

# Node.js Environment
NODE_ENV=production
API_PORT=3001

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/app/logs/application.log

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=50MB

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@samplepos.com

# Error Monitoring (Sentry) — STRONGLY RECOMMENDED
# Without this, production errors are only in server logs
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# Grafana admin password
GRAFANA_PASSWORD=your_secure_grafana_password

# Backup Configuration (Optional — automated backups run via Docker regardless)
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=samplepos-backups
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1